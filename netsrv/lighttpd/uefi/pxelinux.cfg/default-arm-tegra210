DEFAULT primary
TIMEOUT 30
PROMPT 0
MENU TITLE PXELinux boot options
LABEL primary
    MENU LABEL Fedora CoreOS on TFTP
    KERNEL fedora-coreos-40.aarch64/vmlinux
    FDT dtb/nvidia/tegra210-p3450-0000.dtb
    APPEND initrd=fedora-coreos-40.aarch64/initrd.img coreos.live.rootfs_url=http://10.0.0.250:8080/fedora-coreos-40.aarch64/rootfs.img ignition.config.url=http://10.0.0.250:8080/fedora-coreos-40.aarch64/fcos-base.ign ignition.firstboot mitigations=auto,nosmt fbcon=map:0 net.ifnames=0 sdhci_tegra.en_boot_part_access=1 console=ttyS0,115200 console=tty1 rd.shell rd.debug
LABEL jetson-lab
    MENU LABEL Assisted Installer for Jetson Lab OCP
    KERNEL jetson-ocp/vmlinux
    FDT dtb/nvidia/tegra210-p3450-0000.dtb
    APPEND initrd=jetson-ocp/initrd.img coreos.live.rootfs_url=http://10.0.0.199:8888/boot-artifacts/rootfs\?arch=arm64\&version=4.16 random.trust_cpu=on rd.luks.options=discard ignition.firstboot ignition.platform.id=metal console=ttyS0,115200n8 console=tty1 coreos.inst.persistent-kargs="console=ttyS0,115200n8 console=tty1" mitigations=auto,nosmt
IPAPPEND 2
