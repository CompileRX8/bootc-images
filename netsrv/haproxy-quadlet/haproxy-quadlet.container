[Unit]
Description=HAProxy Service

[Install]
WantedBy=default.target

[Service]
Restart=always

[Container]
Image=docker.io/library/haproxy:3.0
ContainerName=haproxy-quadlet
ServiceName=haproxy-quadlet

AddCapability=NET_ADMIN
AddCapability=NET_RAW
AddCapability=CAP_AUDIT_WRITE
AddCapability=NET_BIND_SERVICE

Network=host
HostName=netsrv.highley.net
AddHost=netsrv.highley.net:10.0.0.250

Volume=/var/run:/var/run
Volume=haproxy-quadlet-config:/usr/local/etc/haproxy

